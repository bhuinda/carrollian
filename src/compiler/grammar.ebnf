turn          = request, context?, obligations?, claims?, support?, scene, residue, answer, certificate, replay ;
request       = "00_request.raw.json" ;
context       = "01_context.manifest.json" ;
obligations   = "02_obligations.json" ;
claims        = "03_claims.jsonl" ;
support       = "04_support_ledger.json" ;
scene         = "05_scene.ir.json" ;
actor_trace   = "06_actor_trace.json" ;
lowered_d20   = "07_lowered_d20.json" ;
residue       = "08_residue_ledger.json" ;
verification  = "09_verification_report.json" ;
answer_plan   = "10_answer_plan.md" ;
answer        = "11_final_answer.md" ;
certificate   = "12_turn_certificate.json" ;
replay        = "13_replay.json" ;
failures      = "14_failures.jsonl" ;
metrics       = "15_metrics.json" ;
turn_lock     = "TURN.lock.json" ;

scene         = support_field, effect_field, readout_field, shield_field, sword_field, boundary_field, residue_field, certificate_field ;
support_field = "support" ;
effect_field  = "effect_field" ;
readout_field = "public_readout" ;
shield_field  = "shield_transport" ;
sword_field   = "sword_cut" ;
boundary_field = "boundary" ;
residue_field = "residue" ;
certificate_field = "certificate" ;
