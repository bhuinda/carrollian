{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "guardrails": {
      "type": "object"
    },
    "layer_count": {
      "minimum": 25,
      "type": "integer"
    },
    "manifest_hashes": {
      "type": "object"
    },
    "qstar_full_certificate_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "schema": {
      "const": "qstar.verifier.full_certificate.v37"
    },
    "status": {
      "const": "QSTAR_VERIFIER_FULL_CERTIFIED"
    }
  },
  "required": [
    "schema",
    "status",
    "layer_count",
    "qstar_full_certificate_sha256",
    "manifest_hashes",
    "guardrails"
  ],
  "title": "QSTAR root certificate",
  "type": "object"
}
