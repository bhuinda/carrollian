{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gnatural.external_solver_evidence_manifest.v16.schema.json",
  "title": "Gnatural external solver evidence manifest v16",
  "type": "object",
  "required": [
    "schema",
    "source",
    "solver",
    "artifacts"
  ],
  "properties": {
    "schema": {
      "const": "gnatural.external_solver_evidence_manifest.v16"
    },
    "source": {
      "type": "string",
      "description": "Human-readable source of the log bundle, e.g. local machine / CI run."
    },
    "solver": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "command": {
          "type": "string"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "kind"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "stdout",
              "stderr",
              "drat",
              "lrat",
              "frat",
              "trace",
              "dimacs",
              "other"
            ]
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}