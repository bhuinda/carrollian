{
  "$id": "gnatural.external_solver_evidence_manifest.external_evidence_gate.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "artifacts": {
      "items": {
        "properties": {
          "kind": {
            "enum": [
              "stdout",
              "stderr",
              "drat",
              "lrat",
              "frat",
              "trace",
              "dimacs",
              "other"
            ]
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          }
        },
        "required": [
          "path",
          "kind"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "notes": {
      "type": "string"
    },
    "schema": {
      "const": "gnatural.external_solver_evidence_manifest.external_evidence_gate"
    },
    "solver": {
      "properties": {
        "command": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "source": {
      "description": "Human-readable source of the log bundle, e.g. local machine / CI run.",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "source",
    "solver",
    "artifacts"
  ],
  "title": "Gnatural external solver evidence manifest external_evidence_gate",
  "type": "object"
}
