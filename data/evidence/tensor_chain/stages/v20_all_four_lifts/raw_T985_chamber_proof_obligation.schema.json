{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Raw T985 chamber proof input schema",
  "type": "object",
  "required": [
    "tensor_triples",
    "relation_to_A42_map",
    "A42_to_A12_map",
    "six_object_labels"
  ],
  "properties": {
    "tensor_triples": {
      "description": "Rows [alpha,beta,gamma,p_alpha_beta_gamma] for all nonzero A985 structure constants",
      "type": "string"
    },
    "relation_to_A42_map": {
      "description": "Length-985 map q42(alpha)",
      "type": "string"
    },
    "A42_to_A12_map": {
      "description": "Length-42 map q12(I)",
      "type": "string"
    },
    "six_object_labels": {
      "description": "Ordered H6 labels [B-,B+,V-,V+,S-,S+]",
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 6,
      "maxItems": 6
    }
  }
}