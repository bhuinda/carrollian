{
  "schema": "d20.q_weighted_stack_series.v26.formulas",
  "bounds": {
    "NMAX": 40,
    "QMAX": 512
  },
  "variables": {
    "t": "total dimension",
    "q": "budget weight"
  },
  "pair_kernel": {
    "half": "K_fc(t,q)=sum_{a\u2261f,b\u2261c mod2} t^(a+b) q^(ab)",
    "double": "K_fc(t,q)=sum t^(a+b) q^(2ab)",
    "gauge": "K_fc(t,q)=sum t^(a+b) q^(a^2+b^2)"
  },
  "grade_decomposition": {
    "grade0": "K_00^6",
    "grade1": "binomial(6,3) K_10^3 K_00^3",
    "grade2": "sum_{r in {1,2,4,5,6}} binomial(6,r) K_10^r K_00^(6-r)",
    "grade3": "(K_00+K_10+K_01+K_11)^6 - (K_00+K_10)^6"
  },
  "interpretation": "q-weighted dimension-vector stack counting by half-arrow, doubled-arrow, and gauge budgets; not yet motivic/sheafified CoHA"
}