{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "d20.integrity.v_wall_crossing_certificate.v1",
  "title": "D20 visible V wall-crossing certificate",
  "type": "object",
  "required": [
    "schema",
    "status",
    "event_id",
    "trace_path",
    "integrity_type",
    "class_code",
    "public_boundary",
    "commutator_witness",
    "checks"
  ],
  "properties": {
    "schema": {
      "const": "d20.integrity.v_wall_crossing_certificate.v1"
    },
    "status": {
      "const": "V_WALL_CROSSING_CERTIFICATE"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_path": {
      "type": "string",
      "minLength": 1
    },
    "integrity_type": {
      "const": "V"
    },
    "class_code": {
      "const": "V_VISIBLE_COMMUTATOR_WALL_CROSSING"
    },
    "public_boundary": {
      "type": "object",
      "required": [
        "public_input_hash",
        "public_output_hash",
        "boundary_description"
      ],
      "properties": {
        "public_input_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "public_output_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "boundary_description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "commutator_witness": {
      "type": "object",
      "required": [
        "witness_type",
        "witness_hash",
        "replay_status"
      ],
      "properties": {
        "witness_type": {
          "type": "string",
          "minLength": 1
        },
        "witness_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "replay_status": {
          "const": "REPLAYED"
        }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "object",
      "required": [
        "visible",
        "replayable",
        "locally_checkable",
        "no_hidden_advice",
        "no_x_extractor"
      ],
      "properties": {
        "visible": {
          "type": "boolean"
        },
        "replayable": {
          "type": "boolean"
        },
        "locally_checkable": {
          "type": "boolean"
        },
        "no_hidden_advice": {
          "type": "boolean"
        },
        "no_x_extractor": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
