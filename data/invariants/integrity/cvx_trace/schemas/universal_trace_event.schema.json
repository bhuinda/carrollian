{
  "$id": "d20.integrity.universal_trace_event",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "checks": {
      "additionalProperties": true,
      "properties": {
        "locally_checkable": {
          "type": "boolean"
        },
        "uses_extension_variable": {
          "type": "boolean"
        },
        "uses_hidden_advice": {
          "type": "boolean"
        }
      },
      "required": [
        "locally_checkable",
        "uses_hidden_advice"
      ],
      "type": "object"
    },
    "class_code": {
      "minLength": 1,
      "type": "string"
    },
    "event_id": {
      "minLength": 1,
      "type": "string"
    },
    "integrity_type": {
      "enum": [
        "C",
        "V",
        "X",
        "UNCLASSIFIED"
      ]
    },
    "op": {
      "enum": [
        "universal_machine_opcode",
        "proof_opcode",
        "solver_opcode",
        "visible_wall_crossing",
        "extractor_opcode",
        "residue"
      ]
    },
    "public_inputs": {
      "type": "object"
    },
    "public_outputs": {
      "type": "object"
    },
    "reason": {
      "type": "string"
    },
    "schema": {
      "const": "d20.integrity.universal_trace_event"
    },
    "step": {
      "minimum": 1,
      "type": "integer"
    }
  },
  "required": [
    "schema",
    "event_id",
    "step",
    "op",
    "class_code",
    "integrity_type",
    "public_inputs",
    "public_outputs",
    "checks"
  ],
  "title": "D20 universal C/V/X trace event",
  "type": "object"
}
