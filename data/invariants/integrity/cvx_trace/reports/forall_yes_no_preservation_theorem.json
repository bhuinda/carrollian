  "proof": {
    "completeness": {
      "construction": "Given satisfying assignment a, choose for each clause the least literal index whose literal evaluates true under a. Emit those clause_witness rows and set inverse_projection to a. Each local replay check passes, so the target accepts.",
      "statement": "If phi is satisfiable, then E(phi) has an accepting assignment witness.",
      "witness_size_bound": "assignment bits plus one row per clause: O(n+m), with packet size O(n+m+L)."
    },
    "definitions": {
      "compiled_instance": "E(phi) is the public packet emitted by public_dimacs_to_parameterized_assignment_e33_packet_v0; it copies public clause rows, literal slots, and clause-local gate rows.",
      "source_language": "DIMACS CNF-SAT over variables x_1..x_n and clauses C_0..C_{m-1}.",
      "target_acceptance": "Replay accepts iff every selected literal belongs to its source clause, evaluates true under the projected assignment, every clause has a witness row, and intrinsic rho_33 transport is derived from emitted circuit data without inserting a residual scalar.",
      "target_witness": "A witness W contains assignment_bits plus one selected source literal per clause, with inverse_projection.assignment_bits equal to assignment_bits."
    },
    "no_hidden_advice": {
      "evidence": {
        "compiler_emits_assignment_witness": false,
        "compiler_public_only": true,
        "compiler_uses_hidden_e33_advice": false,
        "compiler_uses_solver_outcome": false
      },
      "statement": "The reduction and proof relation use no hidden-sector advice."
    },
    "soundness": {
      "argument": "Acceptance implies every clause_witness row selects a literal from the corresponding source clause and that literal evaluates true under the inverse-projected assignment. Therefore every source clause is true under that assignment, so phi is satisfiable.",
      "inverse_projection": "The satisfying assignment is exactly assignment_witness.inverse_projection.assignment_bits.",
      "statement": "If E(phi) has an accepting assignment witness, then phi is satisfiable."
    }
  },
