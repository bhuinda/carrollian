    "d20_preservation_test": "test against the certified full augmented D20 ledger stabilizer and the label-relaxed hidden-split C2 quotient",
    "polarity_doubling": "the two residues 2k and 2k+1 attached to each strict weak order",
    "strict_weak_order_clock": "the 13 ordered partitions of the labelled set {a,b,c}, mapped to the even residues 2k modulo 26"
  },
