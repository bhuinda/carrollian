SelectorFiber : Selector → Set
SelectorFiber s = Σ[ d ∈ DynamicsId ] SelectorMembership s d

data SingletonSelector : Set where
  primitiveSeededSingleton : SingletonSelector
  globalActionMinimalSingleton : SingletonSelector
  pairedActionMinimalSingleton : SingletonSelector
  lazySpectralGapActionTiebreakSingleton : SingletonSelector
