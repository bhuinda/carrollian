dynamicsIdDiscrete : Discrete DynamicsId
dynamicsIdDiscrete x y with discreteℕ (dynamicsId x) (dynamicsId y)
... | yes p = yes ((sym (dynamicsIdByIdRoundtrip x)) ∙ (cong dynamicsIdById p) ∙ (dynamicsIdByIdRoundtrip y))
... | no ¬p = no λ q → ¬p (cong dynamicsId q)

dynamicsIdIsSet : isSet DynamicsId
dynamicsIdIsSet = Discrete→isSet dynamicsIdDiscrete
